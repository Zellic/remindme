# Discord bot token (required)
BOT_TOKEN=your_discord_bot_token_here

# Redis connection URL (default: local)
REDIS_URL=redis://localhost:6379

# Prefix for Redis keys (default: remindme-bot)
APPLICATION_KEY=remindme-bot

# Optional: Discord guild/server ID for instant dev command registration.
# Leave blank for global registration (propagates in up to 1 hour).
GUILD_ID=
